# Local secrets for `npm run sync:feeds`.
# Copy this file to `.env` and fill in the values. `.env` is gitignored and
# is loaded automatically by the sync scripts (Node --env-file-if-exists).
#
# In GitHub Actions these come from repository SECRETS, never from this file.
# The Web3Forms key is NOT here — it is public-by-design and lives in
# src/_data/site.json.

YOUTUBE_API_KEY=
IG_ACCESS_TOKEN=
