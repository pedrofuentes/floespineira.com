{# ============================================================ #}
{# IDENTITY / TAGLINE + QUOTE                                    #}
{# ============================================================ #}
<section class="home-identity" aria-label="Identity">
  <div class="container">
    <h2 class="home-identity-heading">Non-Binary Queer Pro Enduro Rider</h2>
    <p class="home-identity-quote">
      <em>&#8220;Never stop believing in yourself because the true energy that moves everything around you comes from within yourself&#8221;</em> &#8211; Flo
    </p>
  </div>
</section>

{# ============================================================ #}
{# CHAMPION SUB-HERO (dark band with trophy photo + titles)      #}
{# ============================================================ #}
<section class="home-titles" aria-label="Achievements">
  <div class="container">
    <div class="home-titles-inner">
      <div class="home-titles-photo">
        <img
          src="/assets/images/Flo2023-800x800.jpg"
          alt="Flo Espineira holding the 2023 Women's E-EDR World Champion trophy"
          loading="lazy"
          width="600"
          height="600"
        />
      </div>
      <div class="home-titles-text">
        <h2 class="home-titles-heading">
          <a href="https://galfer.eu/bike/florencia-espineira-world-champion-e-edr-2023/" target="_blank" rel="noopener">
            Flo is the 2023 Women&#8217;s E-EDR World Champion
          </a>
        </h2>
        <p>Flo has achieved the first-ever title in the history of the UCI Women&#8217;s Enduro World Cup and retains the title as world champion of women&#8217;s electric Enduro.</p>
        <h3 class="home-titles-heading home-titles-heading--prev">
          Previously:
          <a href="https://www.enduroworldseries.com/news/1949-espineira-and-pontal-crowned-2022-ewse-champions/" target="_blank" rel="noopener">
            Flo is the 2022 EWS-e World Champion
          </a>
        </h3>
        <p>Check the <a href="https://www.enduroworldseries.com/rankings/riders/" target="_blank" rel="noopener">EWS-E World Ranking</a> and <a href="https://stories.orbea.com/en/enduro-world-series-flo-espineira/" target="_blank" rel="noopener">Orbea&#8217;s Article</a></p>
      </div>
    </div>
  </div>
</section>

