{% if youtube and youtube.length > 0 %}
<section class="home-section home-section--videos" aria-label="{{ site.home.sections.videos }}">
  <div class="container">
    <h2 class="home-section-heading">{{ site.home.sections.videos }}</h2>
    {% set items = youtube %}
    {% set kind = "video" %}
    {% set feedLimit = 3 %}
    {% include "partials/feed-grid.njk" %}
    {% set feedLimit = 0 %}
    <p class="home-section-more">
      <a href="{{ site.socials.youtube }}" target="_blank" rel="noopener" class="btn">Subscribe ›</a>
    </p>
  </div>
</section>
{% endif %}

