---
layout: base.njk
ogType: article
---

<div class="container post-page">
  <article class="post-article">

    <header class="post-header">
      <h1>{{ title }}</h1>
      <div class="post-meta">
        <time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
      </div>
    </header>

    {% if hero %}
      <div class="post-hero">
        <img src="{{ hero }}" alt="{{ title }}" />
      </div>
    {% endif %}

    <div class="post-content">
      {{ content | safe }}
    </div>

  </article>
</div>
