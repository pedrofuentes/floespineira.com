---
layout: base.njk
title: News — Flo Espiñeira
permalink: /news/
---

<div class="container news-page">
  <h1>News</h1>

  {% if collections.posts and collections.posts.length %}
    <ol class="post-list" style="list-style:none;margin:0;padding:0;">
      {% for post in collections.posts %}
        <li class="post-list-item">
          <h2 class="post-item-title">
            <a href="{{ post.url }}">{{ post.data.title }}</a>
          </h2>
          <div class="post-item-meta">
            Posted on
            <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
          </div>
          <div class="post-item-content">
            {{ post.templateContent | safe }}
          </div>
          <a class="post-item-more" href="{{ post.url }}">Continue reading &#x2192;</a>
        </li>
      {% endfor %}
    </ol>
  {% else %}
    <p class="news-empty">No posts yet — check back soon.</p>
  {% endif %}
</div>
